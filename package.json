{
  "name": "gpsr-image-generator",
  "version": "1.0.2",
  "description": "GPSR image generator desktop app for Windows and macOS.",
  "author": "TaaaaaaNne",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:web-manifest": "python tools/build_web_resource_manifest.py",
    "pack": "npm run build:web-manifest && electron-builder --dir",
    "dist": "npm run build:web-manifest && electron-builder"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.gpsr.imagegenerator",
    "productName": "GPSRImageGenerator",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "web/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "logo.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "logo.icns",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  }
}
